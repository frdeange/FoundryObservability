# =============================================================================
# Azure AI Foundry Observability — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# REQUIRED — Core project settings
# ---------------------------------------------------------------------------

# Your Azure AI Foundry project endpoint.
# Format: https://<account_name>.services.ai.azure.com/api/projects/<project_name>
# Found in: Foundry portal → Project → Overview
AZURE_AI_PROJECT_ENDPOINT=""

# The deployment name of the AI model to use (e.g., gpt-4o-mini).
# Found in: Foundry portal → Build → Models → Deployments table → "Name" column
AZURE_AI_MODEL_DEPLOYMENT_NAME=""

# ---------------------------------------------------------------------------
# REQUIRED for agent examples (06, 10, 11)
# ---------------------------------------------------------------------------

# The name of the AI agent to create/use for evaluation and tracing.
AZURE_AI_AGENT_NAME="ObservabilityDemoAgent"

# ---------------------------------------------------------------------------
# TRACING — Feature gates
# ---------------------------------------------------------------------------

# Enable GenAI telemetry tracing (experimental preview).
# Must be set BEFORE calling AIProjectInstrumentor().instrument().
AZURE_EXPERIMENTAL_ENABLE_GENAI_TRACING=true

# Enable content recording: capture message contents and tool call details.
# WARNING: May contain sensitive user data. Disabled by default.
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true

# ---------------------------------------------------------------------------
# LOCAL TRACING — Aspire Dashboard (OTLP)
# ---------------------------------------------------------------------------

# OTLP endpoint for the Aspire Dashboard running via docker-compose.
# The dashboard UI is at http://localhost:18888
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# OTLP protocol — Aspire Dashboard supports gRPC only.
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# ---------------------------------------------------------------------------
# OPTIONAL — Evaluation with Application Insights traces (example 07)
# ---------------------------------------------------------------------------

# The Azure Application Insights resource ID (for querying traces).
# Format: /subscriptions/<sub_id>/resourceGroups/<rg>/providers/Microsoft.Insights/components/<name>
APPINSIGHTS_RESOURCE_ID=""

# The agent ID emitted by tracing, used to filter traces in App Insights.
AGENT_ID=""

# How many hours back to look when querying traces. Default: 1
TRACE_LOOKBACK_HOURS=1

# ---------------------------------------------------------------------------
# OPTIONAL — Scheduled evaluations (example 09)
# ---------------------------------------------------------------------------

# Azure subscription ID (for RBAC assignment in scheduled evals).
AZURE_SUBSCRIPTION_ID=""

# Resource group name where the Foundry project is located.
AZURE_RESOURCE_GROUP_NAME=""
